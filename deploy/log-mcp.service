[Unit]
Description=Log MCP Server - AI log analysis for BCL services
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=bclai
Group=bclai
WorkingDirectory=/opt/log-mcp
ExecStart=/usr/bin/node /opt/log-mcp/dist/index.js
Restart=always
RestartSec=5
SyslogIdentifier=log-mcp
Environment=NODE_ENV=production
Environment=PORT=3850

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
# Need read access to journal
SupplementaryGroups=systemd-journal

[Install]
WantedBy=multi-user.target
